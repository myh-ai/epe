---
permalink: /feed.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title }}</title>
    <link>{{ '/' | absolute_url }}</link>
    <atom:link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/rss+xml"/>
    <description>{{ site.description | strip_newlines | strip }}</description>
    <language>en</language>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    {%- assign posts = site.pages | where_exp: "p", "p.layout == 'post'" | sort: "date" | reverse -%}
    {%- for post in posts limit: 20 -%}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ post.url | absolute_url }}</link>
      <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      {%- if post.category %}<category>{{ post.category | xml_escape }}</category>{% endif -%}
      <description>{{ post.excerpt | strip_html | xml_escape }}</description>
    </item>
    {%- endfor -%}
  </channel>
</rss>
